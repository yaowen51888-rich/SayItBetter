# ContentCraft AI 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================
# JWT 密钥（买断版激活码签名）
# ============================================================
# 生成方法：npm run generate:secret
# 警告：请妥善保管此密钥，泄露后他人可生成有效激活码
# 密钥长度：256位（32字节）Base64编码
JWT_SECRET=your-secret-key-here

# ============================================================
# 激活码默认配置（可选）
# ============================================================
# 有效期：默认 100y（100年，实际上是永久）
# LICENSE_EXPIRES=100y
# 设备限制：默认 3 台设备
# LICENSE_MAX_DEVICES=3

# ============================================================
# 已废弃配置（订阅制模式，保留用于向后兼容）
# ============================================================
# Supabase配置（旧版订阅制）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Paddle支付配置（旧版订阅制）
PADDLE_VENDOR_ID=your-vendor-id
PADDLE_VENDOR_AUTH_CODE=your-auth-code
PADDLE_WEBHOOK_SECRET=your-webhook-secret
